<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Edward is a personal fork of Ice. Signed Sparkle updates are served from
	     theedward.app. If you fork Edward, replace SUFeedURL and SUPublicEDKey
	     with your own so your build never updates into someone else's binary. -->
	<key>SUFeedURL</key>
	<string>https://theedward.app/appcast.xml</string>
	<key>SUPublicEDKey</key>
	<string>cJmakrF3vQK4AGVxsmD7sZSd2SSH0PtCsxnxMdeOr90=</string>
	<key>SUEnableAutomaticChecks</key>
	<true/>
</dict>
</plist>
