<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Edward is a personal fork of Ice. Placeholder auto-update feed; point it
	     at your own appcast (with your own SUPublicEDKey) if you want signed
	     updates. Auto-checks are off so Edward never tries to update into Ice. -->
	<key>SUFeedURL</key>
	<string>https://jasonsmith.io/edward-releases/appcast.xml</string>
	<key>SUEnableAutomaticChecks</key>
	<false/>
</dict>
</plist>
